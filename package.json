{
  "name": "prometheus",
  "version": "0.10.2",
  "type": "module",
  "description": "C.L.I modular para análise, diagnóstico e manutenção de projetos JavaScript/TypeScript e multi-stack leve",
  "author": "5 5 5",
  "license": "MIT-0",
  "bin": {
    "prometheus": "./dist/bin/index.js"
  },
  "exports": {
    ".": "./dist/bin/index.js"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "prebuild": "rimraf dist bin",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "prepare": "npm run build",
    "start": "prometheus",
    "diagnosticar": "prometheus diagnosticar",
    "padronizar": "prometheus padronizador",
    "importer": "prometheus importer",
    "formatar": "prometheus formatar --write",
    "otimizar": "prometheus otimizar-svg --write",
    "reestruturar": "prometheus reestruturar",
    "podar": "prometheus podar",
    "fix-types": "prometheus fix-types",
    "name": "prometheus names",
    "rename": "prometheus renames",
    "perf:baseline": "prometheus perf snapshot --baseline || true",
    "perf:compare": "prometheus perf compare",
    "perf:gate": "prometheus perf compare --threshold 0",
    "scan": "prometheus licencas scan",
    "add": "prometheus licencas disclaimer add",
    "licenses": "prometheus licencas scan --root .",
    "notices": "prometheus licencas notices generate",
    "verify": "prometheus licencas disclaimer verify",
    "guardian": "prometheus guardian",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --ext .ts src",
    "test": "vitest run --passWithNoTests",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "cli",
    "code-analysis",
    "linter",
    "static-analysis",
    "typescript",
    "javascript",
    "developer-tools",
    "code-quality",
    "architecture",
    "refactoring",
    "monorepo",
    "project-analysis",
    "technical-debt",
    "devtools",
    "maintenance",
    "diagnostics",
    "code-health"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/5-5-5-5-5-5-5/prometheus.git"
  },
  "bugs": {
    "url": "https://github.com/5-5-5-5-5-5-5/prometheus/issues"
  },
  "homepage": "https://github.com/5-5-5-5-5-5-5/prometheus#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE*",
    "THIRD-PARTY-NOTICES.txt",
    "scripts/check-node-version.js"
  ],
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "css-tree": "^3.2.1",
    "fast-xml-parser": "^5.7.2",
    "htmlparser2": "^12.0.0",
    "java-parser": "^3.0.1",
    "micromatch": "^4.0.8",
    "ora": "^9.4.0",
    "p-limit": "^7.3.0",
    "prometheus": "file:prometheus-0.10.2.tgz",
    "xxhashjs": "^0.2.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "license-checker-rseidelsohn": "^4.4.2",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "lodash": "4.18.0",
    "lodash-es": "4.18.0",
    "glob": "^13.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  }
}
